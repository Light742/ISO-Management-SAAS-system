{
    "hosting": {
        "site": "auditflow-malita",
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "firestore": [
        {
            "database": "auditflow-malita",
            "rules": "firestore.rules"
        }
    ]
}